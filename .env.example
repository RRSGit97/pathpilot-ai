# ── LLM Provider ──────────────────────────────────────────────
# Supported: openai | gemini | anthropic
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=your-openai-api-key-here
# GEMINI_API_KEY=your-gemini-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Storage ───────────────────────────────────────────────────
DATABASE_PATH=storage/pathpilot.db

# ── Vector Store (Optional) ──────────────────────────────────
# Set to true to enable Qdrant-backed semantic search.
# When false, a NoOp adapter is used — the app runs fine without Qdrant.
VECTOR_STORE_ENABLED=false
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Feature Flags ─────────────────────────────────────────────
RESUME_UPLOAD_ENABLED=true
DEBUG=false
